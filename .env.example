# Node environment
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/nour?retryWrites=true&w=majority

# Auth.js v5 (generate with: openssl rand -base64 32)
AUTH_SECRET=replace-me-with-a-32-char-secret

# Cloudflare R2 (S3-compatible)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nour-media
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE=https://cdn.example.com
# Maximum allowed audio upload size in bytes (default: 52428800 = 50 MiB).
R2_MAX_UPLOAD_BYTES=52428800

# Public URLs
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Sentry (optional in MVP)
SENTRY_DSN=

# Mobile app origin allowed to call /api/v1 via CORS (Expo dev: http://localhost:8081, prod: app scheme/site).
MOBILE_APP_ORIGIN=http://localhost:8081

# apps/mobile only — Expo inlines EXPO_PUBLIC_* at build time (RN equivalent of NEXT_PUBLIC_*).
# Point at your machine's LAN IP (not localhost) when testing on a physical device.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Playwright E2E (override to run tests against a deployed environment)
PLAYWRIGHT_WEB_URL=http://localhost:3000
PLAYWRIGHT_ADMIN_URL=http://localhost:3001
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
