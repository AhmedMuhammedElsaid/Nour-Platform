{
  "name": "saber-adel-platform",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "predev": "npx kill-port 3000 3001",
    "dev": "turbo run dev",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:web": "turbo run dev --filter=web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "clean": "turbo run clean",
    "seed:admin": "tsx --env-file-if-exists=.env.local scripts/seed-admin.ts",
    "seed:adhkar": "tsx --env-file-if-exists=.env.local scripts/seed-adhkar.ts",
    "seed:quran": "tsx --env-file-if-exists=.env.local scripts/seed-quran.ts",
    "migrate": "tsx --env-file-if-exists=.env.local scripts/migrate.ts",
    "migrate:dry": "pnpm migrate --dry-run",
    "migrate:search": "tsx --env-file-if-exists=.env.local scripts/migrate-search-indexes.ts",
    "heal:slugs": "tsx --env-file-if-exists=.env.local scripts/heal-embedded-slugs.ts",
    "heal:malformed-slugs": "tsx --env-file-if-exists=.env.local scripts/heal-malformed-slugs.ts",
    "reset:admin-password": "tsx --env-file-if-exists=.env.local scripts/reset-admin-password.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tsx": "^4.17.0",
    "turbo": "^2.3.0",
    "typescript": "5.6.3",
    "zod": "^3.23.8"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    },
    "patchedDependencies": {
      "react-native-track-player@4.1.2": "patches/react-native-track-player@4.1.2.patch"
    }
  }
}
