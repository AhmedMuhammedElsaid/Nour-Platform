{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "globalEnv": ["NODE_ENV", "CI", "VERCEL", "VERCEL_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "MONGODB_URI",
        "AUTH_SECRET",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_BUCKET",
        "R2_ENDPOINT",
        "R2_PUBLIC_BASE",
        "R2_MAX_UPLOAD_BYTES",
        "NEXT_PUBLIC_WEB_URL",
        "NEXT_PUBLIC_ADMIN_URL",
        "NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA",
        "SENTRY_DSN",
        "NEXT_PUBLIC_SENTRY_DSN"
      ],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["MONGODB_URI", "AUTH_SECRET"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
