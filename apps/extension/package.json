    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "tailwindcss": "^4.0.0",
    "typescript": "5.6.3",
