{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "production": {
      "android": {
        "buildType": "app-bundle",
        "keystore": {
          "keystorePath": "nour-release-key.keystore",
          "keystorePassword": "env:KEYSTORE_PASSWORD",
          "keyAlias": "nour-release",
          "keyPassword": "env:KEY_PASSWORD"
        }
      },
      "ios": {
        "buildType": "archive"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "buildType": "simulator"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "google-play-key.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "env:APPLE_ID",
        "appleTeamId": "env:APPLE_TEAM_ID",
        "appSpecificPassword": "env:APPLE_APP_PASSWORD"
      }
    }
  }
}
