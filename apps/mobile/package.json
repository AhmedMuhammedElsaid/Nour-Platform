{
  "name": "mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:preview": "set EAS_NO_VCS=1&& eas build -p android --profile preview",
    "build:production": "set EAS_NO_VCS=1&& eas build --profile production",
    "lint": "eslint . --max-warnings 0",
