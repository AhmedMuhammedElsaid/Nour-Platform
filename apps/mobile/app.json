{
  "expo": {
    "name": "Nour",
    "slug": "nour-platform",
    "scheme": "nour",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#0f0d0a",
    "primaryColor": "#c8a050",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0d0a"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#0f0d0a"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Nour to access your location to show accurate prayer times."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#c8a050",
          "sounds": [
            "./assets/audio/adhan_notify.wav"
          ]
        }
      ],
      [
        "expo-quick-actions",
        {
          "androidIcons": {
            "shortcut_adhkar": {
              "foregroundImage": "./assets/android-icon-monochrome.png",
              "backgroundColor": "#0f0d0a"
            }
          }
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "NourHome",
              "label": "Nour — Prayer, Radio & Adhkar",
              "description": "مواقيت الصلاة، الإذاعة، والأذكار",
              "minWidth": "300dp",
              "minHeight": "180dp",
              "targetCellWidth": 5,
              "targetCellHeight": 3,
              "previewImage": "./assets/widget-preview/nour-home.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nour.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "entitlements": {
        "com.apple.developer.usernotifications.critical-alerts": true
      }
    },
    "android": {
      "package": "com.nour.mobile",
      "versionCode": 9,
      "adaptiveIcon": {
        "backgroundColor": "#0E6E59",
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e95180e7-fd4e-464b-a7e9-932b7a2d8e86"
      }
    },
    "owner": "ahmedmuhammedelsaid",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e95180e7-fd4e-464b-a7e9-932b7a2d8e86"
    }
  }
}
