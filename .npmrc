auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
; Metro/Babel resolve plugins by bare name from the app dir; pnpm's isolated
; store hides them, which breaks EAS Android bundling (Cannot find module
; '@babel/plugin-transform-react-jsx'). Hoist all @babel/* to root
; node_modules so name-based resolution works. Specifying public-hoist-pattern
; replaces pnpm's default ['*eslint*','*prettier*'], so re-list those too.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@babel/*
